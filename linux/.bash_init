#!/usr/bin/env bash

# =============================================================================
# Bash Initialization - Advanced Configuration
#
# Repo-managed (~/dotfiles/linux/.bash_init). Refreshed every install.sh run.
# Don't add machine-specific or secret config here — use ~/.bashrc instead.
# =============================================================================

# -----------------------------------------------------------------------------
# Editor / Locale
# -----------------------------------------------------------------------------
export EDITOR="nano"
export SUDO_EDITOR="$EDITOR"
export LC_ALL=en_US.UTF-8

# -----------------------------------------------------------------------------
# History Configuration
# -----------------------------------------------------------------------------
shopt -s histappend
HISTCONTROL=ignoreboth:erasedups
HISTSIZE=32768
HISTFILESIZE="${HISTSIZE}"

# -----------------------------------------------------------------------------
# Path Configuration
# -----------------------------------------------------------------------------
export PATH="$HOME/.local/bin:$PATH"
[ -d "$HOME/dotfiles/bin" ] && export PATH="$HOME/dotfiles/bin:$PATH"
[ -d "$HOME/go/bin" ]       && export PATH="$PATH:$HOME/go/bin"

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
# Tell Mise to automatically load .env files
export MISE_ENV_FILE=.env

# -----------------------------------------------------------------------------
# Color support (Linux uses dircolors)
# -----------------------------------------------------------------------------
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# -----------------------------------------------------------------------------
# Tool Initializations
# -----------------------------------------------------------------------------
# Mise (formerly rtx)
if command -v mise &> /dev/null; then
  eval "$(mise activate bash)"
fi

# Zoxide - smart directory jumping
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init bash)"
else
  unalias cd 2>/dev/null || true
fi

# FZF - fuzzy finder
if command -v fzf &> /dev/null; then
  eval "$(fzf --bash)"
fi

# -----------------------------------------------------------------------------
# Bash Completion
# -----------------------------------------------------------------------------
if [ -f /etc/bash_completion ] && ! shopt -oq posix; then
  . /etc/bash_completion
fi

# -----------------------------------------------------------------------------
# Prompt Configuration
# -----------------------------------------------------------------------------
force_color_prompt=yes
color_prompt=yes

# Simple fallback prompt
PS1='$ '

# Conditional prompt based on Bash version
if ((${BASH_VERSION%%.*} > 4)) && command -v oh-my-posh &> /dev/null; then
    eval "$(oh-my-posh init bash --config $HOME/.config/ohmyposh/zen.toml)"
fi

# -----------------------------------------------------------------------------
# Load inputrc if it exists
# -----------------------------------------------------------------------------
if [[ $- == *i* ]] && [ -f ~/.inputrc ]; then
  bind -f ~/.inputrc
fi
